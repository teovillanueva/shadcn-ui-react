{
  "name": "@teovilla/shadcn-ui-react-root",
  "version": "0.4.0",
  "private": true,
  "scripts": {
    "publish-packages": "turbo run build && changeset version && changeset publish",
    "generate": "pnpm --filter @teovilla/shadcn-ui-generate-script run run",
    "build": "turbo run build",
    "template:dev": "pnpm --filter next-shadcn-ui run dev"
  },
  "workspaces": {
    "packages": [
      "packages/generated/*",
      "packages/*",
      "templates/*",
      "scripts/*"
    ]
  },
  "dependencies": {
    "tsup": "^6.7.0"
  },
  "devDependencies": {
    "changesets": "^1.0.2",
    "turbo": "^1.7.0"
  }
}
